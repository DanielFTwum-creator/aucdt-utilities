# Lecturer AI Handbook — runtime environment (self-serving-Node)
#
# This app holds NO Gemini key (Pattern 11). GEMINI_PROXY_KEY is the WMS relay
# service credential; it is injected on the server at deploy time from
# /opt/tuc-wms/.env (file-to-file, never on the dev machine, never echoed) — do
# NOT put a real value here. All AI calls relay to WMS, which adds the real key.
GEMINI_PROXY_KEY=

# Set by deploy.ps1; gates the production self-serving-Node branch in server.ts.
NODE_ENV=production
PORT=3042

# Optional overrides (sensible defaults in code):
# WMS_BASE=http://127.0.0.1:8081            # server-side WMS for the /api/me token check
# WMS_GEMINI_URL=https://wms.techbridge.edu.gh/api/gemini/generate
# VITE_WMS_BASE=https://wms.techbridge.edu.gh  # client SSO base (build-time)

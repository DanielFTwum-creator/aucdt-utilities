# LyriaStream — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── AIM ───────────────────────────────────────────────────────────────────────
AIM_API_KEY=change-me-strong-random-key-shared-with-gateway

# Compute mode: auto | cpu_draft | gpu_fast | gpu_full
COMPUTE_MODE=cpu_draft

# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change-me-root
DB_USER=lyriastream
DB_PASSWORD=change-me-db-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-minimum-512-bit-secret-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TOTP (Admin 2FA) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
TOTP_ENCRYPTION_KEY=change-me-32-char-key-exactly!!!

# ── Audio storage ─────────────────────────────────────────────────────────────
AUDIO_STORAGE_PATH=/var/lyriastream/audio

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://lyriastream.techbridge.edu.gh

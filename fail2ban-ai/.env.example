# fail2ban-ai server environment.
#
# GEMINI_PROXY_KEY: WMS relay service credential (Pattern 11). This app never
# holds the real Gemini key. The deploy script injects this value on the
# server, file-to-file from /opt/tuc-wms/.env — it never exists on a dev
# machine and must never be typed on a command line.
GEMINI_PROXY_KEY=

# PORT: fleet assignment is 3040 (SERVER_PORTS.md). The server defaults to
# 3040 when unset.
PORT=3040

# WMS_GEMINI_URL: override only for testing against a non-production WMS.
# WMS_GEMINI_URL=https://wms.techbridge.edu.gh/api/gemini/generate

# WMS_BASE: server-to-server WMS base for the SSO token check (requireWmsAuth
# validates Bearer tokens against WMS /api/me). Defaults to the loopback so it
# bypasses the public WAF; override only for off-box testing.
# WMS_BASE=http://127.0.0.1:8081

# VITE_WMS_BASE: browser-side WMS origin for the SSO redirect and token calls.
# Baked into the build; defaults to https://wms.techbridge.edu.gh.
# VITE_WMS_BASE=https://wms.techbridge.edu.gh

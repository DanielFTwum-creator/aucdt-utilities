# Example environment variables
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=https://your-api.com/api

# Test Runner Configuration
NEXT_PUBLIC_TEST_TARGET=https://admissions.techbridge.edu.gh

# Optional: Real-time WebSocket
NEXT_PUBLIC_WS_URL=ws://your-server.com/tests

# Optional: Email notifications
NEXT_PUBLIC_NOTIFICATION_EMAIL=daniel.twum@techbridge.edu.gh

# Feature Flags
NEXT_PUBLIC_ENABLE_RUN_BUTTON=true
NEXT_PUBLIC_ENABLE_AUTO_REFRESH=true

# bridge-radio server environment (server-side only — never exposed to the client)

# Port the Express/tsx server listens on (registered in SERVER_PORTS.md).
PORT=3021

# Run mode. Production serves the built dist/; otherwise Vite middleware (dev).
NODE_ENV=production

# --- Gemini key custody (PATTERNS.md #11) -----------------------------------
# Production: authenticates with the WMS proxy which holds the real key.
GEMINI_PROXY_KEY="set-on-server-via-pm2-or-.env.local"

# Local dev fallback only — used when GEMINI_PROXY_KEY is not set.
# NEVER commit a real key; the client bundle must not contain it.
GEMINI_API_KEY="local-dev-only-optional"

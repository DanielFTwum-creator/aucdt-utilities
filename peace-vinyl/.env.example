# Peace Vinyl Environment Configuration
# Use .env.local for local development, .env.production for Plesk deployment

# ============ GOOGLE OAUTH ============

# Client ID (public, safe to expose)
VITE_GOOGLE_CLIENT_ID=537671076222-q0ovngh3m2m560kdcrsn2hk0cae5rudg.apps.googleusercontent.com

# Redirect URI - changes per environment
# - Local development: http://localhost:3000/auth/google/callback
# - Production (Plesk): https://ai-tools.techbridge.edu.gh/peace/auth/google/callback
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Client Secret (PRIVATE - server-side only)
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   - http://localhost:3000/auth/google/callback (local)
#   - https://ai-tools.techbridge.edu.gh/peace/auth/google/callback (production)
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# ============ GEMINI API ============

# Gemini API Key for music generation features
VITE_GEMINI_API_KEY=<REDACTED_OLD_GEMINI_KEY>

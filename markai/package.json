{
  "name": "markai-ai-marketing-for-non-marketers",
  "packageManager": "pnpm@11.5.3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.cjs",
    "dev:server": "node server.cjs",
    "start": "node server.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm exec playwright test --config playwright.config.ts",
    "e2e:build": "cross-env VITE_COVERAGE=true vite build",
    "e2e:cypress": "cypress run",
    "e2e:open": "cypress open",
    "e2e:coverage-report": "nyc report --reporter=text-summary --reporter=html --report-dir=coverage-e2e"
  },
  "nyc": {
    "report-dir": "coverage-e2e",
    "temp-dir": ".nyc_output",
    "include": [
      "components/**",
      "contexts/**",
      "services/**",
      "App.tsx",
      "index.tsx"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.16.0",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@playwright/browser-chromium": "^1.60.0",
    "@playwright/browser-firefox": "^1.60.0",
    "@playwright/browser-webkit": "^1.60.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.30",
    "cross-env": "^10.1.0",
    "cypress": "^15.17.0",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.6"
  }
}

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
coverage-e2e/
.nyc_output/
*.lcov

# Production builds
dist/
build/

# Maven / TS build artifacts (generated output, never commit)
target/
*.tsbuildinfo

# Cypress generated artifacts (videos/screenshots are run output, not source)
**/cypress/videos/
**/cypress/screenshots/

# Security incident reports — local only, never push to the public mirror
docs/SECURITY-INCIDENT-*

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
temp.env

# Cloud credentials — never commit
service-account.json

# Read-only clones of the legacy Bitbucket fleet (15 nested git repos)
legacy-bitbucket-repos/

# Standalone git repo living alongside the monorepo (own history, not a submodule)
techbridge-ship1-starter/

# One-off Google Drive data backups (8MB+ JSON, external-storage material)
tuc-curriculum-merge/backups/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vitest
.vitest/

# Claude Code agent worktrees (ephemeral, contain their own git state)
.claude/worktrees/

# Claude Code local machine state (never commit)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Cygwin / Git-Bash crash dumps
*.stackdump

# Build logs
*build*.log
*.log

# Large binary / media files — use external storage (S3, Drive, etc.)
*.pbtxt
*.heic
*.HEIC
*.webm
*.mp4
*.pptx
*.pdf
*.db-wal
*.xlsx

# Playwright / test artefacts
**/.cache/ms-playwright/
**/playwright-browsers/
**/playwright-report/data/
**/test-results/
**/tests/results/
**/tests/accessibility-report/
**/.antigravity/

# Catalogue screenshots (generated, not source)
catalogue/project-screenshots/
catalogue/*/screenshot.png

# Prompt history exports
**/migrated_prompt_history/

FROM node:24-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY src/ ./src/
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:' + (process.env.PORT || 4002) + '/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode);})"
EXPOSE 4002
CMD ["node", "src/index.js"]

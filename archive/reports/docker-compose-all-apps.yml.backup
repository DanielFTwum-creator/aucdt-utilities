  # ========================================
  # BACKEND API (Critical Infrastructure)
  # ========================================
  tuc-auth-api:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: tuc-auth-api
    environment:
      NODE_ENV: production
      PORT: 3000
    env_file:
      - ./backend/.env
    networks:
      - tuc-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:3000/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"]
      interval: 30s
      timeout: 10s
      retries: 3
    profiles:
      - core
      - full


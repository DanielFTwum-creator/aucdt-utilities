  # ====================
  # Full-Stack Services (Express + React)
  # Recently Added: 2026-02-27
  # ====================

  tuc-mysql:
    image: mysql:8.0
    container_name: tuc-mysql
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD:-tuc_root_2026}
      MYSQL_DATABASE: ${MYSQL_DATABASE:-tuc_services}
    volumes:
      - mysql-data:/var/lib/mysql
    networks:
      - tuc-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-p${MYSQL_ROOT_PASSWORD:-tuc_root_2026}"]
      interval: 30s
      timeout: 10s
      retries: 3
    profiles:
      - core
      - full

  accommodation-management:
    build:
      context: ./accommodation-management
      dockerfile: ../Dockerfile.fullstack
    container_name: accommodation-management
    environment:
      NODE_ENV: production
      PORT: 4053
      API_PORT: 4053
      DB_HOST: tuc-mysql
      DB_USER: root
      DB_PASSWORD: ${MYSQL_ROOT_PASSWORD:-tuc_root_2026}
      DB_NAME: accommodation_management
    depends_on:
      - tuc-mysql
    networks:
      - tuc-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    profiles:
      - standard
      - full


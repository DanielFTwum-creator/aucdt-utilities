  internship-program:
    build:
      context: ./internship-program
      dockerfile: Dockerfile.prod
    container_name: internship-program
    environment:
      NODE_ENV: production
      PORT: 4058
      DB_HOST: tuc-mysql
      DB_USER: root
      DB_PASSWORD: ${MYSQL_ROOT_PASSWORD:-tuc_root_2026}
      DB_NAME: internship_program
    depends_on:
      - tuc-mysql
    networks:
      - tuc-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:4058/health', (r) => { if (r.statusCode !== 200) throw new Error(r.statusCode) })"]
      interval: 30s
      timeout: 10s
      retries: 3
    profiles:
      - standard
      - full

networks:
  tuc-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16

volumes:
  node_modules:
  mysql-data:

# Docker Compose - All TUC Applications
# Last Updated: 2026-02-27
# Total Projects: 109 (100 Vite/React + 9 Backend Services)
# Services Configured: 109 (100% COVERAGE ACHIEVED!)
# Core: 8 | Standard: 89 | Full-Stack Services: 8
# THE AGENT Book: Foundation for scaling to 256 managed applications

services:

  nginx-gateway:
    image: nginx:alpine
    container_name: tuc-gateway
    ports:
      - "8080:80"
    volumes:
      - ./docker/nginx/nginx-all-apps.conf:/etc/nginx/conf.d/default.conf:ro
      - ./docker/nginx/html:/usr/share/nginx/html:ro
    depends_on:
      - analytics-refactor
      - tuc-analytics-dashboard
      - tuc-website-react
      - fees-comparison-dashboard
      - kanban-app
      - techbridge-product-design-6r-design-portal
    networks:
      - tuc-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3
  analytics-refactor:
    build:
      context: ./analytics-refactor
      dockerfile: ../Dockerfile.vite
    container_name: analytics-refactor
    environment:
      NODE_ENV: production
    networks:
      - tuc-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3

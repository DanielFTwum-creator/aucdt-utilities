{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/session-governance.mjs"],
            "statusMessage": "Loading aucdt-utilities governance (PATTERNS index, CONSTRAINTS list)…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/no-npm.mjs"],
            "statusMessage": "Checking for pnpm compliance…"
          }
        ]
      }
    ]
  }
}

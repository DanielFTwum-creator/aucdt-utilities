import React from 'react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Progress } from '@/components/ui/progress';
import { 
  Users,
  Globe,
  GraduationCap,
  MapPin,
  UserCheck,
  Calendar,
  Award,
  BookOpen
} from 'lucide-react';

import { DonutChart } from '../charts/DonutChart';

interface FunnelData {
  timeSeriesData: Array<{
    month: string;
    signups: number;
    applicants: number;
    accepted: number;
    registered: number;
  }>;
  totalMetrics: {
    totalSignups: number;
    totalApplicants: number;
    totalAccepted: number;
    totalRegistered: number;
    acceptedNotRegistered: number;
    signupsNeverApplied: number;
    overallConversionRate: number;
  };
  conversionRates: {
    signupToApplication: number;
    applicationToAcceptance: number;
    acceptanceToRegistration: number;
  };
}

interface DemographicsTabProps {
  data: FunnelData | null;
}

export function DemographicsTab({ data }: DemographicsTabProps) {
  if (!data) {
    return <div className="text-center py-8">No data available</div>;
  }

  const formatNumber = (num: number) => num.toLocaleString();
  const formatPercentage = (num: number) => `${num.toFixed(1)}%`;

  // Generate realistic demographic distributions based on typical university patterns
  const generateDemographics = () => {
    // Gender distribution (typical university demographics)
    const genderDistribution = [
      { name: 'Female', value: Math.round(data.totalMetrics.totalSignups * 0.58), color: '#f472b6' },
      { name: 'Male', value: Math.round(data.totalMetrics.totalSignups * 0.40), color: '#3b82f6' },
      { name: 'Other/Prefer not to say', value: Math.round(data.totalMetrics.totalSignups * 0.02), color: '#10b981' }
    ];

    // Age distribution (typical for university applicants)
    const ageDistribution = [
      { name: '17-19', value: Math.round(data.totalMetrics.totalSignups * 0.45), color: '#8b5cf6' },
      { name: '20-22', value: Math.round(data.totalMetrics.totalSignups * 0.30), color: '#06b6d4' },
      { name: '23-25', value: Math.round(data.totalMetrics.totalSignups * 0.15), color: '#f59e0b' },
      { name: '26-30', value: Math.round(data.totalMetrics.totalSignups * 0.07), color: '#ef4444' },
      { name: '30+', value: Math.round(data.totalMetrics.totalSignups * 0.03), color: '#6b7280' }
    ];

    // Geographic distribution (UAE-focused with international mix)
    const geographicDistribution = [
      { name: 'UAE', value: Math.round(data.totalMetrics.totalSignups * 0.35), color: '#10b981' },
      { name: 'GCC Countries', value: Math.round(data.totalMetrics.totalSignups * 0.25), color: '#3b82f6' },
      { name: 'Other MENA', value: Math.round(data.totalMetrics.totalSignups * 0.20), color: '#f59e0b' },
      { name: 'South Asia', value: Math.round(data.totalMetrics.totalSignups * 0.12), color: '#8b5cf6' },
      { name: 'Other International', value: Math.round(data.totalMetrics.totalSignups * 0.08), color: '#ef4444' }
    ];

    // Academic background (typical for university applications)
    const academicBackground = [
      { name: 'High School Graduate', value: Math.round(data.totalMetrics.totalSignups * 0.70), color: '#3b82f6' },
      { name: 'Foundation Program', value: Math.round(data.totalMetrics.totalSignups * 0.15), color: '#10b981' },
      { name: 'Transfer Student', value: Math.round(data.totalMetrics.totalSignups * 0.10), color: '#f59e0b' },
      { name: 'Graduate Degree', value: Math.round(data.totalMetrics.totalSignups * 0.05), color: '#8b5cf6' }
    ];

    // Program interest (based on typical university offerings)
    const programInterest = [
      { name: 'Business & Management', value: Math.round(data.totalMetrics.totalSignups * 0.25), color: '#3b82f6' },
      { name: 'Engineering', value: Math.round(data.totalMetrics.totalSignups * 0.20), color: '#10b981' },
      { name: 'Computer Science & IT', value: Math.round(data.totalMetrics.totalSignups * 0.18), color: '#8b5cf6' },
      { name: 'Healthcare Sciences', value: Math.round(data.totalMetrics.totalSignups * 0.12), color: '#f472b6' },
      { name: 'Arts & Humanities', value: Math.round(data.totalMetrics.totalSignups * 0.10), color: '#f59e0b' },
      { name: 'Social Sciences', value: Math.round(data.totalMetrics.totalSignups * 0.08), color: '#06b6d4' },
      { name: 'Other Programs', value: Math.round(data.totalMetrics.totalSignups * 0.07), color: '#6b7280' }
    ];

    return {
      gender: genderDistribution,
      age: ageDistribution,
      geographic: geographicDistribution,
      academic: academicBackground,
      programs: programInterest
    };
  };

  const demographics = generateDemographics();

  // Calculate conversion rates by segment (example analysis)
  const conversionAnalysis = {
    gender: [
      { segment: 'Female', conversion: data.totalMetrics.overallConversionRate * 1.08, count: demographics.gender[0].value },
      { segment: 'Male', conversion: data.totalMetrics.overallConversionRate * 0.95, count: demographics.gender[1].value },
      { segment: 'Other', conversion: data.totalMetrics.overallConversionRate * 1.02, count: demographics.gender[2].value }
    ],
    age: [
      { segment: '17-19', conversion: data.totalMetrics.overallConversionRate * 1.15, count: demographics.age[0].value },
      { segment: '20-22', conversion: data.totalMetrics.overallConversionRate * 1.05, count: demographics.age[1].value },
      { segment: '23-25', conversion: data.totalMetrics.overallConversionRate * 0.90, count: demographics.age[2].value },
      { segment: '26-30', conversion: data.totalMetrics.overallConversionRate * 0.75, count: demographics.age[3].value },
      { segment: '30+', conversion: data.totalMetrics.overallConversionRate * 0.60, count: demographics.age[4].value }
    ],
    geographic: [
      { segment: 'UAE', conversion: data.totalMetrics.overallConversionRate * 1.20, count: demographics.geographic[0].value },
      { segment: 'GCC', conversion: data.totalMetrics.overallConversionRate * 1.10, count: demographics.geographic[1].value },
      { segment: 'MENA', conversion: data.totalMetrics.overallConversionRate * 0.95, count: demographics.geographic[2].value },
      { segment: 'South Asia', conversion: data.totalMetrics.overallConversionRate * 0.85, count: demographics.geographic[3].value },
      { segment: 'International', conversion: data.totalMetrics.overallConversionRate * 0.70, count: demographics.geographic[4].value }
    ]
  };

  return (
    <div className="space-y-6">
      {/* Demographics Overview */}
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center space-x-2">
            <Users className="h-6 w-6 text-blue-600" />
            <span>Student Demographics Overview</span>
          </CardTitle>
          <p className="text-sm text-gray-600">
            Comprehensive breakdown of student applicant demographics and conversion patterns
          </p>
        </CardHeader>
        <CardContent>
          <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div className="text-center">
              <div className="text-3xl font-bold text-blue-600">
                {formatNumber(data.totalMetrics.totalSignups)}
              </div>
              <p className="text-sm text-gray-600">Total Applicants</p>
              <Badge variant="secondary" className="mt-2">All Demographics</Badge>
            </div>
            
            <div className="text-center">
              <div className="text-3xl font-bold text-green-600">
                {demographics.geographic.filter(item => item.name === 'UAE')[0]?.value || 0}
              </div>
              <p className="text-sm text-gray-600">UAE Nationals</p>
              <Badge variant="secondary" className="mt-2">
                {formatPercentage((demographics.geographic.filter(item => item.name === 'UAE')[0]?.value || 0) / data.totalMetrics.totalSignups * 100)}
              </Badge>
            </div>
            
            <div className="text-center">
              <div className="text-3xl font-bold text-purple-600">
                {demographics.gender.filter(item => item.name === 'Female')[0]?.value || 0}
              </div>
              <p className="text-sm text-gray-600">Female Applicants</p>
              <Badge variant="secondary" className="mt-2">
                {formatPercentage((demographics.gender.filter(item => item.name === 'Female')[0]?.value || 0) / data.totalMetrics.totalSignups * 100)}
              </Badge>
            </div>
            
            <div className="text-center">
              <div className="text-3xl font-bold text-orange-600">
                {demographics.age.filter(item => item.name === '17-19')[0]?.value || 0}
              </div>
              <p className="text-sm text-gray-600">Traditional Age (17-19)</p>
              <Badge variant="secondary" className="mt-2">
                {formatPercentage((demographics.age.filter(item => item.name === '17-19')[0]?.value || 0) / data.totalMetrics.totalSignups * 100)}
              </Badge>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Demographic Distribution Charts */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center space-x-2">
              <UserCheck className="h-5 w-5 text-pink-600" />
              <span>Gender Distribution</span>
            </CardTitle>
          </CardHeader>
          <CardContent>
            <DonutChart
              data={demographics.gender}
              title="Gender Breakdown"
            />
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="flex items-center space-x-2">
              <Calendar className="h-5 w-5 text-purple-600" />
              <span>Age Distribution</span>
            </CardTitle>
          </CardHeader>
          <CardContent>
            <DonutChart
              data={demographics.age}
              title="Age Group Breakdown"
            />
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="flex items-center space-x-2">
              <Globe className="h-5 w-5 text-green-600" />
              <span>Geographic Distribution</span>
            </CardTitle>
          </CardHeader>
          <CardContent>
            <DonutChart
              data={demographics.geographic}
              title="Regional Breakdown"
            />
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="flex items-center space-x-2">
              <GraduationCap className="h-5 w-5 text-blue-600" />
              <span>Academic Background</span>
            </CardTitle>
          </CardHeader>
          <CardContent>
            <DonutChart
              data={demographics.academic}
              title="Educational Background"
            />
          </CardContent>
        </Card>
      </div>

      {/* Program Interest */}
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center space-x-2">
            <BookOpen className="h-5 w-5 text-indigo-600" />
            <span>Program Interest Analysis</span>
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <DonutChart
                data={demographics.programs}
                title="Program Preferences"
              />
            </div>
            <div className="space-y-4">
              <h4 className="font-semibold text-gray-900">Program Popularity Ranking</h4>
              <div className="space-y-3">
                {demographics.programs.map((program, index) => (
                  <div key={program.name} className="space-y-2">
                    <div className="flex justify-between items-center">
                      <span className="text-sm font-medium text-gray-700">
                        {index + 1}. {program.name}
                      </span>
                      <span className="text-sm text-gray-600">
                        {formatNumber(program.value)} applicants
                      </span>
                    </div>
                    <Progress 
                      value={(program.value / data.totalMetrics.totalSignups) * 100} 
                      className="h-2"
                    />
                    <p className="text-xs text-gray-500">
                      {formatPercentage((program.value / data.totalMetrics.totalSignups) * 100)} of total applicants
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Conversion Analysis by Demographics */}
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center space-x-2">
            <Award className="h-5 w-5 text-yellow-600" />
            <span>Conversion Rate Analysis by Demographics</span>
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <h4 className="font-semibold text-gray-900 mb-4">By Gender</h4>
              <div className="space-y-3">
                {conversionAnalysis.gender.map((item) => (
                  <div key={item.segment} className="flex justify-between items-center">
                    <span className="text-sm text-gray-600">{item.segment}</span>
                    <div className="flex items-center space-x-2">
                      <span className="text-sm font-medium">
                        {formatPercentage(item.conversion)}
                      </span>
                      <Badge 
                        variant={item.conversion > data.totalMetrics.overallConversionRate ? "default" : "secondary"}
                        className="text-xs"
                      >
                        {item.conversion > data.totalMetrics.overallConversionRate ? 'Above Avg' : 'Below Avg'}
                      </Badge>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h4 className="font-semibold text-gray-900 mb-4">By Age Group</h4>
              <div className="space-y-3">
                {conversionAnalysis.age.map((item) => (
                  <div key={item.segment} className="flex justify-between items-center">
                    <span className="text-sm text-gray-600">{item.segment}</span>
                    <div className="flex items-center space-x-2">
                      <span className="text-sm font-medium">
                        {formatPercentage(item.conversion)}
                      </span>
                      <Badge 
                        variant={item.conversion > data.totalMetrics.overallConversionRate ? "default" : "secondary"}
                        className="text-xs"
                      >
                        {item.conversion > data.totalMetrics.overallConversionRate ? 'Above Avg' : 'Below Avg'}
                      </Badge>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h4 className="font-semibold text-gray-900 mb-4">By Region</h4>
              <div className="space-y-3">
                {conversionAnalysis.geographic.map((item) => (
                  <div key={item.segment} className="flex justify-between items-center">
                    <span className="text-sm text-gray-600">{item.segment}</span>
                    <div className="flex items-center space-x-2">
                      <span className="text-sm font-medium">
                        {formatPercentage(item.conversion)}
                      </span>
                      <Badge 
                        variant={item.conversion > data.totalMetrics.overallConversionRate ? "default" : "secondary"}
                        className="text-xs"
                      >
                        {item.conversion > data.totalMetrics.overallConversionRate ? 'Above Avg' : 'Below Avg'}
                      </Badge>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Demographic Insights */}
      <Card className="bg-gradient-to-r from-blue-50 to-indigo-50">
        <CardHeader>
          <CardTitle className="flex items-center space-x-2">
            <MapPin className="h-5 w-5 text-indigo-600" />
            <span>Demographic Insights & Opportunities</span>
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div className="space-y-3">
              <h4 className="font-semibold text-gray-900">Key Observations</h4>
              <ul className="space-y-2 text-sm text-gray-700">
                <li>• Female applicants show higher conversion rates</li>
                <li>• Traditional age students (17-19) convert best</li>
                <li>• UAE nationals have the highest success rate</li>
                <li>• Business programs attract the most interest</li>
                <li>• High school graduates form the majority</li>
              </ul>
            </div>
            
            <div className="space-y-3">
              <h4 className="font-semibold text-gray-900">Growth Opportunities</h4>
              <ul className="space-y-2 text-sm text-gray-700">
                <li>• Target underrepresented male segments</li>
                <li>• Expand GCC regional outreach</li>
                <li>• Develop programs for mature students</li>
                <li>• Enhance STEM program visibility</li>
                <li>• Support transfer student pathways</li>
              </ul>
            </div>
            
            <div className="space-y-3">
              <h4 className="font-semibold text-gray-900">Strategic Recommendations</h4>
              <ul className="space-y-2 text-sm text-gray-700">
                <li>• Customize marketing by demographic</li>
                <li>• Implement targeted conversion strategies</li>
                <li>• Monitor demographic trends quarterly</li>
                <li>• Develop diversity & inclusion initiatives</li>
                <li>• Create age-appropriate support services</li>
              </ul>
            </div>
          </div>
          
          <div className="mt-6 p-4 bg-yellow-50 rounded-lg border border-yellow-200">
            <p className="text-sm text-yellow-800">
              <strong>Note:</strong> Demographic data shown is modeled based on typical university patterns. 
              For precise targeting and strategy development, collect actual demographic data through application forms and surveys.
            </p>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}

    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/playfair-display": "^5.2.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.3.0",

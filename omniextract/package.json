{
  "packageManager": "pnpm@11.5.3",
  "name": "omniextract",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "cy:open": "cypress open --config-file cypress.config.ts",
    "cy:run": "cypress run --config-file cypress.config.ts",
    "cy:run:auth": "cypress run --config-file cypress.config.ts --spec cypress/e2e/auth.cy.ts",
    "cy:run:extraction": "cypress run --config-file cypress.config.ts --spec cypress/e2e/extraction.cy.ts",
    "cy:run:ui": "cypress run --config-file cypress.config.ts --spec cypress/e2e/ui.cy.ts"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jspdf": "2.5.1",
    "lucide-react": "^0.400.0",
    "pdfjs-dist": "3.11.174",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.1.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.17.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "cypress": "^13.17.0",
    "jsdom": "^26.1.0",
    "serve": "14.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "7.3.1",
    "vitest": "^3.0.0"
  }
}

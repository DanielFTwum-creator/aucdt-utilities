{
  "entities": {
    "Reading": {
      "title": "Blood Glucose Reading",
      "description": "A daily record of a user's blood glucose measurements.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "fasting": { "type": "string" },
        "post_breakfast": { "type": "string" },
        "pre_lunch": { "type": "string" },
        "post_lunch": { "type": "string" },
        "pre_dinner": { "type": "string" },
        "post_dinner": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["id", "date", "userId", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user such as Patient Name and Doctor Name.",
      "type": "object",
      "properties": {
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "patientName", "doctorName", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "Documents storing user profile details. The document ID is the userId."
    },
    "/users/{userId}/readings/{readingId}": {
      "schema": { "$ref": "Reading" },
      "description": "Documents storing the daily blood glucose readings for a particular user."
    }
  }
}

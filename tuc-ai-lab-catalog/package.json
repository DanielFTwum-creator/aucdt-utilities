{
  "name": "tuc-ai-lab-catalog",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers tsx server.ts",
    "build": "vite build && cross-env PLAYWRIGHT_BROWSERS_PATH=dist/playwright-browsers pnpm exec playwright install chromium && node -e \"require('fs').copyFileSync('server.ts', 'dist/server.ts')\" && node -e \"require('fs').copyFileSync('package.json', 'dist/package.json')\"",
    "build:web": "vite build",
    "build:ios": "pnpm run build:web && pnpm exec capacitor build ios",
    "build:android": "pnpm run build:web && pnpm exec capacitor build android",
    "start": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers tsx server.ts",
    "install:linux-deps": "sudo pnpm exec playwright install-deps chromium",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "pnpm exec playwright test",
    "test:ui": "pnpm exec playwright test --ui",
    "ios:open": "open ios/App/App.xcworkspace",
    "android:open": "open android",
    "mobile:sync": "capacitor sync"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@google/genai": "^2.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.12"
  }
}

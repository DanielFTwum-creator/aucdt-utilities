{
  "name": "stockpulse",
  "packageManager": "pnpm@11.5.3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "cd backend && pnpm dev",
    "dev:all": "concurrently -n \"API,UI\" -c \"blue,green\" \"pnpm --filter stockpulse-backend run dev\" \"vite --port=3000 --host=0.0.0.0\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:cy": "cypress run",
    "test:cy:open": "cypress open"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.8.1"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.5",
      "react-dom": "19.2.5"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.2",
    "cypress": "^15.17.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  }
}

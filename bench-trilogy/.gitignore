# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# content-extraction scratch (subagent working files, not deliverables)
/content/_*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Intentional self-hosted site media (small clips that must ship with the build).
# Overrides the repo-wide *.mp4 rule for this directory only; large media still
# belongs in external storage.
!/public/videos/*.mp4

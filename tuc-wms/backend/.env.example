# TUC-WMS backend environment (SRS TUC-ICT-SRS-2026-004 v1.0.1 §3.3)
# Copy to .env and fill real values. NEVER commit .env.

# --- Google Workspace OAuth 2.0 / OIDC (from the TUC Google admin console) ---
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret           # never commit
GOOGLE_REDIRECT_URI=https://wms.techbridge.edu.gh/api/auth/google/callback

# --- FR-AUTH-009 domain enforcement ---
ALLOWED_DOMAIN=@techbridge.edu.gh

# --- TUC-WMS JWT (FR-AUTH-002) ---
JWT_SECRET=                # min 256-bit; generate: openssl rand -hex 32
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# --- TOTP MFA (FR-AUTH-008) ---
TOTP_ISSUER=TUC-WMS

# --- Server / DB (production: MariaDB on TUC stack, port 3307) ---
PORT=8080
DB_URL=jdbc:mariadb://localhost:3307/tuc_wms
DB_USER=tuc_wms_user
DB_PASSWORD=
DDL_AUTO=update

# --- Frontend (UI delivered separately) ---
FRONTEND_BASE=https://wms.techbridge.edu.gh

# TUC-WMS backend — LOCAL DEV environment (copy to .env, fill the two secrets).
# Local end-to-end with REAL Google, OAuth routed through the Vite proxy (5174).
# H2 in-memory DB → zero external services. NEVER commit .env.

# --- Shared TUC Google OAuth client (reuse BiochemAI's client; see memory:
#     shared_oauth_biochemai). Paste the real shared values here. ---
GOOGLE_CLIENT_ID=PASTE_SHARED_BIOCHEMAI_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=PASTE_SHARED_BIOCHEMAI_CLIENT_SECRET

# Browser only ever sees localhost:5174; Vite proxies /api -> backend:8081.
# This EXACT URI must be added to the shared client's Authorized redirect URIs.
GOOGLE_REDIRECT_URI=http://localhost:5174/api/auth/google/callback

# FR-AUTH-009 domain gate (unchanged for local).
ALLOWED_DOMAIN=@techbridge.edu.gh

# Local JWT secret (any >=32 bytes is fine for dev; generate: openssl rand -hex 32).
JWT_SECRET=dev-local-insecure-secret-change-me-min-32-bytes-long!!
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

TOTP_ISSUER=TUC-WMS

# Backend on 8081 (the Vite proxy target). H2 in-memory: no MariaDB needed.
PORT=8081
DB_URL=jdbc:h2:mem:tucwms;DB_CLOSE_DELAY=-1;MODE=MySQL
DB_USER=sa
DB_PASSWORD=
DDL_AUTO=update

# SPA origin for the post-login redirect + CORS allow-origin.
FRONTEND_BASE=http://localhost:5174

# Gemini key proxy — leave BLANK for local dev (/api/gemini/generate returns 503,
# /api/gemini/status reports enabled:false). Set a real key only to test the live round-trip.
GEMINI_API_KEY=

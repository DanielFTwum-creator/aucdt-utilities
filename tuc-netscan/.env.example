# TUC NetScan — Environment Variables
# Copy to .env and fill real values before production deployment.
# NEVER commit the real .env to source control.

SPRING_PROFILES_ACTIVE=dev

# Database (TUC standard port 3307)
DB_USERNAME=netscan
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_64_CHARS_MINIMUM

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Network
SCAN_SUBNETS=192.168.1.0/24,10.0.0.0/24
SNMP_COMMUNITY_ENCRYPTED=public

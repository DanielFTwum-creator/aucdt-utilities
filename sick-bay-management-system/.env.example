# SickBay Management System — Environment Configuration
# Copy to .env and populate with production values

# Server
PORT=3046
NODE_ENV=production

# Database — app instance MariaDB 10.3 on 3306 (NEVER 3307, that is the LMS).
# SickBay gets its OWN scoped non-root user with localhost-only grants (Pattern 37).
# Do NOT reuse another app's user (e.g. wms_user). Set DB_PASS on the server via nano.
DB_HOST=localhost
DB_PORT=3306
DB_USER=sickbay_app
DB_PASS=
DB_NAME=tuc_sickbay

# WMS SSO Integration
WMS_BASE=https://wms.techbridge.edu.gh

# Gemini API (for AI features)
GEMINI_API_KEY=

# App URL
APP_URL=https://ai-tools.techbridge.edu.gh/sickbay
